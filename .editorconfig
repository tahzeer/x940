root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_size = 4

[*.toml]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.{md,rst}]
indent_size = 4
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[*.{js,mjs,cjs,ts}]
indent_size = 2

[Makefile]
indent_style = tab
